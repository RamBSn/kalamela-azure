# Copy this file to .env for local testing, or set these as Azure App Settings.

# REQUIRED in production — use a long random string (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string

# REQUIRED — admin login password
ADMIN_PASSWORD=change-me

# REQUIRED on Azure — persistent directory for SQLite DB, uploads, and backups.
# On Azure App Service Linux the /home directory is persistent (Azure Files mount).
# Set this in Azure App Settings:  DATA_DIR=/home/kalamela
DATA_DIR=/home/kalamela
